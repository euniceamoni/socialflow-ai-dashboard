{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.test.ts", "**/tests/**/*.test.ts"],
  "globalSetup": "<rootDir>/src/__tests__/setup.ts",
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js",
    "^.*/services/geminiService$": "<rootDir>/src/__tests__/integration/__mocks__/geminiService.js"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/server.ts",
    "!src/tracing.ts"
  ],
  "coverageReporters": ["text", "lcov", "html", "json-summary"],
  "coverageDirectory": "coverage",
  "coverageThreshold": {
    "global": {
      "lines": 80,
      "statements": 80,
      "functions": 80,
      "branches": 70
    }
  },
  "projects": [
    {
      "displayName": "unit",
      "preset": "ts-jest",
      "testEnvironment": "node",
      "roots": ["<rootDir>/src"],
      "testMatch": [
        "**/__tests__/*.test.ts",
        "**/tests/**/*.test.ts",
        "**/services/__tests__/**/*.test.ts"
      ],
      "moduleNameMapper": {
        "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js",
        "^.*/services/geminiService$": "<rootDir>/src/__tests__/integration/__mocks__/geminiService.js"
      }
    },
    {
      "displayName": "e2e",
      "preset": "ts-jest",
      "testEnvironment": "node",
      "roots": ["<rootDir>/src"],
      "testMatch": ["**/__tests__/integration/*.e2e.test.ts"],
      "moduleNameMapper": {
        "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js",
        "^.*/services/geminiService$": "<rootDir>/src/__tests__/integration/__mocks__/geminiService.js"
      },
      "transform": {
        "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
      },
      "testTimeout": 15000
    },
    {
      "displayName": "db",
      "preset": "ts-jest",
      "testEnvironment": "node",
      "roots": ["<rootDir>/src"],
      "testMatch": ["**/__tests__/database/*.db.test.ts"],
      "moduleNameMapper": {
        "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js"
      },
      "transform": {
        "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
      },
      "testTimeout": 30000
    },
    {
      "displayName": "mocks",
      "preset": "ts-jest",
      "testEnvironment": "node",
      "roots": ["<rootDir>/src"],
      "testMatch": ["**/__tests__/mocks/*.mock.test.ts"],
      "moduleNameMapper": {
        "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js"
      },
      "transform": {
        "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
      },
      "testTimeout": 10000
    }
  ]
}
